// === РАЗДЕЛ 1: ЛОГИКА ДЛЯ ROOT (100% ОЧИСТКА) ===
// Этот код запускается, когда пользователь жмет оранжевую кнопку
try {
    // Получаем права суперпользователя
    java.lang.Process su = Runtime.getRuntime().exec("su");
    java.io.DataOutputStream out = new java.io.DataOutputStream(su.getOutputStream());

    // Команды на удаление системного мусора и папок игры
    out.writeBytes("pm uninstall com.mojang.minecraftpe\n"); // Удаление пакета
    out.writeBytes("rm -rf /data/data/com.mojang.minecraftpe\n"); // Внутренние данные
    out.writeBytes("rm -rf /sdcard/Android/data/com.mojang.minecraftpe\n"); // Внешние данные
    out.writeBytes("rm -rf /sdcard/games/com.mojang\n"); // Папка с мирами (очистка)
    
    out.writeBytes("exit\n");
    out.flush();
    su.waitFor();
    
    // Уведомление об успехе
    android.widget.Toast.makeText(getApplicationContext(), "✅ Очистка завершена! Можно устанавливать.", android.widget.Toast.LENGTH_LONG).show();
} catch (Exception e) {
    // Если Root не найден или произошла ошибка
    android.widget.Toast.makeText(getApplicationContext(), "❌ Ошибка или Root не найден", android.widget.Toast.LENGTH_SHORT).show();
}


// === РАЗДЕЛ 2: ЛОГИКА БЕЗ ROOT (ПОМОЩНИК) ===
